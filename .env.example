# Server
PORT=8080
HOST=0.0.0.0

# Database
DATABASE_URL=postgres://your_username:your_password@localhost:5432/your_database_name
POSTGRES_USER=your_username
POSTGRES_PASSWORD=your_password
POSTGRES_DB=your_database_name

# Security — JWT_SECRET must be at least 32 characters; generate with:
#   openssl rand -base64 48
JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_STRING_AT_LEAST_32_CHARACTERS

# CORS — set to your frontend's origin (never use * in production)
ALLOWED_ORIGIN=http://localhost:3000

# Frontend URL — used to build password reset links in emails
APP_URL=http://localhost:3000

# SMTP — required for password reset emails
# For Gmail: use an App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=your_email@gmail.com

# Logging — options: error, warn, info, debug, trace
RUST_LOG=info
